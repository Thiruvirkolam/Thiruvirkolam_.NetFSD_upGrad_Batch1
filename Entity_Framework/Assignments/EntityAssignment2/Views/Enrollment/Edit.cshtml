@model EntityAssignment2.Models.Enrollment

<h2>Edit Enrollment</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>Student</label>
        <select asp-for="StudentId" asp-items="ViewBag.Students"></select>
    </div>

    <div>
        <label>Course</label>
        <select asp-for="CourseId" asp-items="ViewBag.Courses"></select>
    </div>

    <div>
        <label asp-for="Grade"></label>
        <input asp-for="Grade" />
    </div>

    <button type="submit">Update</button>
    <a asp-action="Index">Cancel</a>
</form>