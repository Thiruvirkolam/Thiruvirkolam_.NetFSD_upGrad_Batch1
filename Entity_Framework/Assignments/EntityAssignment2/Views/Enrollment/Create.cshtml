@model EntityAssignment2.Models.Enrollment

<form asp-action="Create" method="post">
    <div>
        <label>Student</label>
        <select asp-for="StudentId" asp-items="ViewBag.Students"></select>
    </div>

    <div>
        <label>Course</label>
        <select asp-for="CourseId" asp-items="ViewBag.Courses"></select>
    </div>

    <div>
        <label asp-for="Grade"></label>
        <input asp-for="Grade" />
    </div>

    <button type="submit">Save</button>
</form>